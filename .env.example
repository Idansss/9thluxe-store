# ------------------------------------------------------------------
# Fàdè Essence — environment. Validated by lib/env.ts (Zod).
# Copy to .env. Do NOT commit real secrets. Use SANDBOX/TEST keys only in dev.
# ------------------------------------------------------------------

# Database (Neon, Supabase, or any Postgres)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DB?pgbouncer=true&connection_limit=1"

# App
APP_URL="http://localhost:3000"

# NextAuth (either AUTH_SECRET or NEXTAUTH_SECRET)
NEXTAUTH_SECRET="your-nextauth-secret-here"
NEXTAUTH_URL="http://localhost:3000"

# --- Payments: Paystack (SANDBOX/TEST keys only; never live charges in dev) ---
PAYSTACK_SECRET_KEY="sk_test_xxx"
PAYSTACK_PUBLIC_KEY="pk_test_xxx"

# --- Email: Resend ---
RESEND_API_KEY="your-resend-api-key-here"
# Verify your domain in Resend, then set the From address:
NEWSLETTER_FROM_EMAIL="Fàdè <newsletter@yourdomain.com>"

# --- Shopify (optional; store runs on local Postgres commerce until these are set) ---
# When set AND feature flag `shopify_commerce` is enabled, commerce routes through Shopify.
SHOPIFY_STORE_DOMAIN=""            # e.g. your-store.myshopify.com
SHOPIFY_STOREFRONT_API_TOKEN=""
SHOPIFY_ADMIN_API_TOKEN=""
SHOPIFY_API_VERSION="2025-01"
SHOPIFY_WEBHOOK_SECRET=""

# --- AI (provider-independent; default is the offline deterministic mock) ---
AI_PROVIDER="mock"                 # mock | anthropic | openai
ANTHROPIC_API_KEY=""
OPENAI_API_KEY=""
XAI_API_KEY=""

# --- Messaging (optional; no real messages sent in dev) ---
WHATSAPP_TOKEN=""
WHATSAPP_PHONE_ID=""
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_FROM=""

# --- Commerce policy (overrides lib/config/commerce.ts defaults; no hard-coded thresholds) ---
COMMERCE_CURRENCY="NGN"
COMMERCE_FREE_SHIPPING_THRESHOLD_NGN="500000"
COMMERCE_FLAT_SHIPPING_NGN="2500"

# --- Feature flags (comma-separated). Prefix with ! to force-disable a default-on flag. ---
# Available: shopify_commerce, ai_concierge, loyalty_rewards, referral_rewards,
#            sample_credits, whatsapp_marketing, agentic_feed
FEATURE_FLAGS=""
